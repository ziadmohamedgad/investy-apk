@page "/assets"
@implements IDisposable
@inject LocalDatabase Database
@inject PortfolioService Portfolio
@inject EodhdMobileService Eodhd
@inject NavigationManager Nav
@inject BalanceVisibilityService Balance

<PageTitle>حالة الأصول</PageTitle>

<section class="page-head">
    <div>
        <h1>حالة الأصول</h1>
        <p>متوسط الشراء والقيمة السوقية والربح حسب كل أصل</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="notice">@message</div>
}

<section class="asset-stack">
    @foreach (var item in holdings)
    {
        <article class="asset-tile">
            <div class="asset-main">
                <span class="code @CodeClass(item.Asset)">@item.Asset.AssetCode</span>
                <div class="asset-meta">
                    <strong>@item.Asset.AssetName</strong>
                    <small>@AssetTypeLabel(item.Asset)</small>
                </div>
            </div>

            <div class="stat-grid @(item.IsClosedPosition ? "closed-position-grid" : "")">
                @if (item.IsClosedPosition)
                {
                    <span class="closed-pnl-stat">إجمالي الربح/الخسارة المحققة <b class="@($"{Tone(item.RealizedPnL + item.UnrealizedPnL)} {BalanceClass}")">@MoneyValue(item.RealizedPnL + item.UnrealizedPnL)</b></span>
                    <button class="danger compact-action asset-action-button icon-only-asset-action closed-delete-action" title="حذف" aria-label="حذف الأصل" @onclick="() => RequestDeleteAsset(item.Asset.AssetId)"><span aria-hidden="true">🗑</span></button>
                }
                else if (item.Asset.IsDailyAccrualFund)
                {
                    <span>إجمالي الربح/الخسارة غير المحققة <b class="@($"{Tone(item.UnrealizedPnL)} {BalanceClass}")">@MoneyValue(item.UnrealizedPnL) <small>@PercentValue(item.UnrealizedPnLPercent)</small></b></span>
                    <span>إجمالي الربح/الخسارة المحققة <b class="@($"{Tone(item.RealizedPnL)} {BalanceClass}")">@MoneyValue(item.RealizedPnL)</b></span>
                    <span class="market-value-stat">القيمة السوقية <b class="@BalanceClass">@MoneyValue(item.CurrentValue)</b></span>
                }
                else
                {
                    <span>الكمية <b class="@BalanceClass">@item.TotalUnitsHeld.ToString("N2")</b></span>
                    <span>متوسط الشراء <b class="@BalanceClass">@item.AverageBuyPrice.ToString("N2")</b></span>
                    <span>السعر الحالي <b class="@BalanceClass">@item.CurrentPrice.ToString("N2")</b></span>
                    <span>إجمالي المدفوع بالرسوم <b class="@BalanceClass">@MoneyValue(item.TotalPaidIncludingFees)</b></span>
                    <span>إجمالي الربح/الخسارة غير المحققة <b class="@($"{Tone(item.UnrealizedPnL)} {BalanceClass}")">@MoneyValue(item.UnrealizedPnL) <small>@PercentValue(item.UnrealizedPnLPercent)</small></b></span>
                    <span>إجمالي الربح/الخسارة المحققة <b class="@($"{Tone(item.RealizedPnL)} {BalanceClass}")">@MoneyValue(item.RealizedPnL)</b></span>
                    <span class="market-value-stat">القيمة السوقية <b class="@BalanceClass">@MoneyValue(item.CurrentValue)</b></span>
                }
            </div>

            @if (!item.IsClosedPosition)
            {
                <div class="inline-form asset-controls">
                @if (item.Asset.IsDailyAccrualFund)
                {
                    <button class="ghost compact-action asset-action-button" @onclick="() => OpenPriceEditor(item)">تعديل النسبة</button>
                }
                else
                {
                    <button class="ghost compact-action asset-action-button" @onclick="() => OpenPriceEditor(item)">تعديل السعر</button>
                }
                @if (item.Asset.AssetType == AssetType.Stock && !string.IsNullOrWhiteSpace(item.Asset.ExternalTicker))
                {
                    <button class="ghost compact-action asset-action-button" title="مزامنة السعر" @onclick="() => SyncAssetPriceAsync(item.Asset)">مزامنة السعر</button>
                }
                <button class="danger compact-action asset-action-button icon-only-asset-action" title="حذف" aria-label="حذف الأصل" @onclick="() => RequestDeleteAsset(item.Asset.AssetId)"><span aria-hidden="true">🗑</span></button>
                </div>
            }
        </article>
    }
</section>

@if (priceEditorAsset != null)
{
    <div class="confirm-backdrop" @onclick="CancelPriceEditor">
        <div class="confirm-card price-edit-card" @onclick:stopPropagation>
            <strong>@PriceEditorTitle</strong>
            @if (priceEditorAsset.IsDailyAccrualFund)
            {
                <label>
                    النسبة السنوية
                    <input class="field" type="number" step="0.00001" @bind="manualAnnualRateValue" @bind:event="oninput" />
                </label>
            }
            else
            {
                <label>
                    السعر الجديد
                    <input class="field" type="number" step="0.00001" @bind="manualPriceValue" @bind:event="oninput" />
                </label>
                @if (priceEditorAsset.AssetType == AssetType.Gold)
                {
                    <label>
                        الكاش باك للجرام
                        <input class="field" type="number" step="0.00001" @bind="manualGoldCashbackValue" @bind:event="oninput" />
                    </label>
                }
            }
            <div class="confirm-actions">
                <button class="ghost" @onclick="CancelPriceEditor">إلغاء</button>
                <button class="primary" @onclick="SaveAssetEditorAsync">حفظ</button>
            </div>
        </div>
    </div>
}

@if (pendingDeleteAssetId.HasValue)
{
    <div class="confirm-backdrop" @onclick="CancelDeleteAsset">
        <div class="confirm-card" @onclick:stopPropagation>
            <strong>تأكيد الحذف</strong>
            <p>هل تريد حذف هذا الأصل؟ سيتم حذف معاملاته وأسعاره المرتبطة به.</p>
            <div class="confirm-actions">
                <button class="ghost" @onclick="CancelDeleteAsset">إلغاء</button>
                <button class="danger" @onclick="ConfirmDeleteAssetAsync">حذف</button>
            </div>
        </div>
    </div>
}

@code {
    private List<AssetSummary> holdings = new();
    private string? message;
    private int? pendingDeleteAssetId;
    private Asset? priceEditorAsset;
    private decimal? manualPriceValue;
    private decimal? manualGoldCashbackValue;
    private decimal? manualAnnualRateValue;

    protected override async Task OnInitializedAsync()
    {
        if (!await Eodhd.HasApiKeyAsync())
        {
            Nav.NavigateTo("/", replace: true);
            return;
        }

        Balance.Changed += OnBalanceChanged;
        await ReloadAsync();
    }

    private void OnBalanceChanged() => InvokeAsync(StateHasChanged);

    private async Task ReloadAsync()
    {
        holdings = await Portfolio.GetHoldingsAsync();
    }

    private void OpenPriceEditor(AssetSummary item)
    {
        priceEditorAsset = item.Asset;
        manualPriceValue = item.CurrentPrice;
        manualGoldCashbackValue = item.Asset.GoldCashbackPerGram;
        manualAnnualRateValue = item.Asset.DailyAccrualAnnualRatePercent;
    }

    private void CancelPriceEditor()
    {
        priceEditorAsset = null;
        manualPriceValue = null;
        manualGoldCashbackValue = null;
        manualAnnualRateValue = null;
    }

    private async Task SaveAssetEditorAsync()
    {
        if (priceEditorAsset == null)
        {
            return;
        }

        if (priceEditorAsset.IsDailyAccrualFund)
        {
            if (!manualAnnualRateValue.HasValue || manualAnnualRateValue.Value <= 0)
            {
                return;
            }

            priceEditorAsset.DailyAccrualAnnualRatePercent = manualAnnualRateValue.Value;
            await Database.SaveAssetAsync(priceEditorAsset);
            CancelPriceEditor();
            await ReloadAsync();
            await ShowMessageAsync("تم تحديث النسبة.");
            return;
        }

        if (!manualPriceValue.HasValue || manualPriceValue.Value < 0)
        {
            return;
        }

        await Database.SavePriceAsync(new AssetPrice { AssetId = priceEditorAsset.AssetId, PriceDate = DateTime.Today, PriceValue = manualPriceValue.Value, Source = PriceSource.Manual });
        if (priceEditorAsset.AssetType == AssetType.Gold && manualGoldCashbackValue.HasValue && manualGoldCashbackValue.Value >= 0)
        {
            priceEditorAsset.GoldCashbackPerGram = manualGoldCashbackValue.Value;
            await Database.SaveAssetAsync(priceEditorAsset);
        }

        CancelPriceEditor();
        await ReloadAsync();
        await ShowMessageAsync("تم تحديث السعر.");
    }

    private async Task SyncAssetPriceAsync(Asset asset)
    {
        var price = await Eodhd.FetchLatestPriceAsync(asset.ExternalTicker ?? asset.AssetCode);
        if (price == null)
        {
            await ShowMessageAsync("تعذر تحديث سعر الأصل.");
            return;
        }

        await Database.SavePriceAsync(new AssetPrice
        {
            AssetId = asset.AssetId,
            PriceDate = price.Value.Date.Date,
            PriceValue = price.Value.Price,
            Source = PriceSource.Eodhd
        });
        await ReloadAsync();
        await ShowMessageAsync($"تم تحديث سعر {asset.AssetCode}.");
    }

    private void RequestDeleteAsset(int id)
    {
        pendingDeleteAssetId = id;
    }

    private void CancelDeleteAsset()
    {
        pendingDeleteAssetId = null;
    }

    private async Task ConfirmDeleteAssetAsync()
    {
        if (!pendingDeleteAssetId.HasValue)
        {
            return;
        }

        var id = pendingDeleteAssetId.Value;
        pendingDeleteAssetId = null;
        await Database.DeleteAssetAsync(id);
        await ReloadAsync();
        await ShowMessageAsync("تم حذف الأصل.");
    }

    private string Money(decimal value) => Balance.HideBalances ? "••••••" : $"{value.ToString("N2")} ج.م";
    private string BalanceClass => Balance.HideBalances ? "balance-value is-hidden" : "balance-value";
    private string PriceEditorTitle => priceEditorAsset?.IsDailyAccrualFund == true
        ? $"تعديل النسبة - {priceEditorAsset.AssetName}"
        : $"تحديث سعر - {priceEditorAsset?.AssetName}";
    private string MoneyValue(decimal value) => $"{value.ToString("N2")} \u062c.\u0645";
    private string PercentValue(decimal value) => $"{value.ToString("N2")}%";
    private static string Tone(decimal value) => value > 0 ? "positive" : value < 0 ? "negative" : string.Empty;
    private static string CodeClass(Asset asset) => asset.AssetType == AssetType.Gold ? "gold" : asset.AssetType != AssetType.Stock ? "blue" : string.Empty;
    private static string AssetTypeLabel(Asset asset) => asset.IsDailyAccrualFund ? "صندوق ثاندر كلاود لحظي" : asset.AssetType.ToString();

    private async Task ShowMessageAsync(string text)
    {
        message = text;
        StateHasChanged();
        await Task.Delay(1750);
        if (message == text)
        {
            message = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        Balance.Changed -= OnBalanceChanged;
    }
}



