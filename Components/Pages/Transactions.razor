@page "/transactions"
@implements IDisposable
@inject LocalDatabase Database
@inject PortfolioService Portfolio
@inject EodhdMobileService Eodhd
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject BalanceVisibilityService Balance

<PageTitle>العمليات</PageTitle>

<section class="page-head">
    <div>
        <h1>العمليات</h1>
        <p>إضافة وتعديل عمليات الشراء والبيع والأرباح</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="notice @(messageIsError ? "is-error" : "")">@message</div>
}

<section class="surface" id="transaction-editor">
    <div class="section-title">
        <h2>@(editingTransactionId.HasValue ? "تعديل عملية" : "إضافة عملية")</h2>
        <div class="segmented">
            <button class="@(formOpen && entryMode == "stock" ? "selected" : "")" @onclick='() => OpenForm("stock")'>سهم</button>
            <button class="@(formOpen && entryMode == "other" ? "selected" : "")" @onclick='() => OpenForm("other")'>أصل آخر</button>
        </div>
    </div>

    @if (formOpen)
    {
        <div class="mobile-form collapsible-form">
            @if (entryMode == "stock")
            {
                <label>
                    البحث عن سهم بالكود
                    <input class="field ascii-only" data-asset-code-input="true" @bind="StockQueryInput" @bind:event="oninput" @bind:after="OnStockQueryChangedAsync" disabled="@editingTransactionId.HasValue" />
                </label>
                @if (stockSuggestions.Count > 0)
                {
                    <div class="suggestions">
                        @foreach (var item in stockSuggestions)
                        {
                            <button @onclick="() => PickStock(item)">@item.Code - @item.Name</button>
                        }
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(assetName))
                {
                    <div class="selected-asset">@assetName</div>
                }
            }
            else
            {
                <label>
                    نوع الأصل
                    <select class="field" @bind="manualType" @bind:after="OnManualTypeChanged" disabled="@editingTransactionId.HasValue">
                        <option value="Fund">صندوق / مؤشر</option>
                        <option value="Gold">ذهب</option>
                        <option value="Silver">فضة</option>
                        <option value="TCD">صندوق ثاندر كلاود لحظي</option>
                        <option value="Other">أخرى (عقار، ممتلكات، إلخ)</option>
                    </select>
                </label>
                <label>
                    كود الأصل
                    <input class="field ascii-only" data-asset-code-input="true" @bind="AssetCodeInput" @bind:event="oninput" @bind:after="OnManualAssetCodeChangedAsync" disabled="@editingTransactionId.HasValue" />
                </label>
                @if (manualSuggestions.Count > 0)
                {
                    <div class="suggestions">
                        @foreach (var item in manualSuggestions)
                        {
                            <button @onclick="() => PickManualAsset(item)">@item.Code - @item.Name</button>
                        }
                    </div>
                }
                <label>
                    اسم الأصل
                    <input class="field ascii-only" value="@assetName" @oninput="OnAssetNameChanged" disabled="@editingTransactionId.HasValue" />
                </label>
            }

            <label>
                نوع العملية
                <select class="field" @bind="transactionType">
                    <option value="Buy">@(IsTcd ? "إيداع" : "شراء")</option>
                    <option value="Sell" disabled="@(!CanSelectSell)">@(IsTcd ? "سحب" : "بيع")</option>
                    @if (entryMode == "stock")
                    {
                        <option value="Dividend" disabled="@(!CanSelectDividend)">أرباح</option>
                    }
                </select>
                @if (transactionType == "Sell" && !CanSelectSell)
                {
                    <small class="field-hint">@(IsTcd ? "السحب متاح بعد وجود إيداع سابق." : "البيع متاح بعد وجود عملية شراء سابقة.")</small>
                }
                @if (transactionType == "Dividend" && !CanSelectDividend)
                {
                    <small class="field-hint">الأرباح متاحة بعد وجود عملية شراء سابقة للسهم.</small>
                }
            </label>

            @* Dividend sub-type: Cash or Stock *@
            @if (IsDividend)
            {
                <label>
                    نوع الربح
                    <select class="field" @bind="dividendKind">
                        <option value="Cash">نقدية</option>
                        <option value="Stock">أسهم مجانية</option>
                    </select>
                </label>
            }

            @if (!IsTcd)
            {
                <label>
                    التاريخ
                    <input class="field" type="date" max="@TodayIso" @bind="transactionDate" />
                    @if (IsFutureTransactionDate)
                    {
                        <small class="field-hint is-error">لا يمكن تسجيل عملية بتاريخ مستقبلي.</small>
                    }
                </label>
            }

            @if (IsDividend && dividendKind == "Cash")
            {
                <label>
                    الربح النقدي
                    <input class="field" type="number" step="0.01" min="0" @bind="dividendAmount" @bind:event="onchange" />
                    @if (DividendInvalid)
                    {
                        <small class="field-hint is-error">الربح يجب أن يكون أكبر من صفر.</small>
                    }
                </label>
            }
            else if (IsDividend && dividendKind == "Stock")
            {
                <label>
                    عدد الأسهم المجانية لكل سهم ممتلك
                    <input class="field" type="number" step="0.0001" min="0" @bind="freeSharesQuantity" @bind:event="onchange" />
                    @if (FreeSharesInvalid)
                    {
                        <small class="field-hint is-error">العدد يجب أن يكون أكبر من صفر.</small>
                    }
                </label>
            }
            else if (!IsDividend)
            {
                <label>
                    @(IsGoldOrSilver ? "عدد الجرامات" : IsTcd ? "المبلغ" : "الوحدات")
                    <input class="field" type="number" step="0.01" max="@AvailableSellMaxAttribute" @bind="quantity" @bind:event="onchange" />
                    @if (transactionType == "Sell" && CanSelectSell)
                    {
                        <small class="field-hint">المتاح: @AvailableSellLabel</small>
                    }
                    @if (SellExceedsAvailable)
                    {
                        <small class="field-hint is-error">القيمة تتخطى المتاح لهذا الأصل.</small>
                    }
                </label>
            }

            @if (IsTcd && transactionType == "Buy")
            {
                <label>
                    النسبة السنوية
                    <input class="field" type="number" step="0.01" min="0" @bind="dailyAccrualAnnualRatePercent" @bind:event="onchange" />
                    @if (TcdExistingRate.HasValue)
                    {
                        <small class="field-hint">الحالية: @TcdExistingRate.Value.ToString("N2")%</small>
                    }
                    @if (IsTcdAnnualRateRequired)
                    {
                        <small class="field-hint is-error">النسبة السنوية مطلوبة عند إضافة صندوق ثاندر كلاود لأول مرة.</small>
                    }
                </label>
            }
            @if (!IsTcd && !IsDividend)
            {
                <label>
                    @(IsGoldOrSilver ? "السعر للجرام" : "السعر للوحدة")
                    <input class="field" type="number" step="0.00001" @bind="pricePerUnit" @bind:event="onchange" />
                </label>
            }
            @if (IsGoldOrSilver)
            {
                <label>
                    @(transactionType == "Buy" ? "المصنعية للجرام" : "الكاش باك للجرام")
                    <input class="field" type="number" step="0.00001" @bind="manufacturingFeePerGram" @bind:event="onchange" />
                </label>
            }
            @if (!IsTcd && !IsDividend)
            {
                <label>
                    الرسوم
                    <input class="field" type="number" step="0.00001" @bind="fees" @bind:event="onchange" />
                </label>
            }
            @if (!IsDividend)
            {
                <div class="transaction-total @(SellExceedsAvailable || SellNetInvalid || SellExceedsMarketValue ? "is-danger" : "")">
                    <span>الإجمالي</span>
                    <strong class="@BalanceClass">@MoneyValue(TransactionNetAmount)</strong>
                    @if (SellNetInvalid)
                    {
                        <small>@NetSellWarningText</small>
                    }
                    @if (SellExceedsMarketValue)
                    {
                        <small>@NetSellWarningText</small>
                    }
                </div>
            }
        </div>

        <div class="form-actions">
            <button class="ghost" @onclick="CloseForm">إلغاء</button>
            <button class="primary" @onclick="SaveTransactionAsync" disabled="@IsSaveDisabled">@SubmitLabel</button>
        </div>
    }
</section>

<section class="surface" id="transactions-list-start">
    <div class="section-title">
        <h2>العمليات</h2>
        <span>@transactions.Count عملية</span>
    </div>

    <div class="transaction-stack">
        @foreach (var transaction in transactions)
        {
            var asset = assets.FirstOrDefault(a => a.AssetId == transaction.AssetId);
            var isTcdTx = asset?.IsDailyAccrualFund == true;
            <article class="transaction-card @(transaction.TransactionType == TransactionKind.Dividend ? "is-dividend" : "")">
                <div class="transaction-head">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <span class="code @CodeClass(asset)">@asset?.AssetCode</span>
                        <small style="color: var(--muted); font-size: 0.85rem;">@AssetTypeLabel(asset)</small>
                    </div>
                    <div class="transaction-meta" dir="rtl">
                        <strong class="@TransactionTypeClass(transaction)">@TransactionTypeLabel(transaction, asset)</strong>
                        <small>@transaction.TransactionDate.ToString("yyyy/MM/dd")</small>
                    </div>
                </div>
                <div class="transaction-numbers">
                    @if (transaction.TransactionType == TransactionKind.Dividend)
                    {
                        @* Cash dividend or stock dividend - show net only *@
                        <span class="transaction-net-only">
                            @if (transaction.DividendKind == DividendKind.Stock)
                            {
                                @* Stock dividend: show free shares and market price *@
                                <span>أسهم مجانية <b class="@BalanceClass">@transaction.Quantity.ToString("N2") سهم</b></span>
                            }
                            else
                            {
                                @* Cash dividend *@
                                <span>الصافي <b class="@BalanceClass">@MoneyValue(transaction.NetAmount)</b></span>
                            }
                        </span>
                    }
                    else if (isTcdTx)
                    {
                        @* TCD: show net amount only (no units or price) *@
                        <span class="transaction-net-only">الصافي <b class="@BalanceClass">@MoneyValue(transaction.NetAmount)</b></span>
                    }
                    else
                    {
                        <span>الوحدات <b class="@BalanceClass">@transaction.Quantity.ToString("N2")</b></span>
                        <span>السعر <b class="@BalanceClass">@MoneyValue(transaction.PricePerUnit)</b></span>
                        <span>الصافي <b class="@BalanceClass">@MoneyValue(transaction.NetAmount)</b></span>
                    }
                </div>
                <div class="row-actions">
                    <button class="ghost" @onclick="() => EditTransactionAsync(transaction.TransactionId)">تعديل</button>
                    <button class="danger" @onclick="() => RequestDeleteTransaction(transaction.TransactionId)">حذف</button>
                </div>
            </article>
        }
    </div>
</section>

@if (pendingDeleteTransactionId.HasValue)
{
    <div class="confirm-backdrop" @onclick="CancelDeleteTransaction">
        <div class="confirm-card" @onclick:stopPropagation>
            <strong>تأكيد الحذف</strong>
            <p>هل تريد حذف هذه العملية؟</p>
            <div class="confirm-actions">
                <button class="ghost" @onclick="CancelDeleteTransaction">إلغاء</button>
                <button class="danger" @onclick="ConfirmDeleteTransactionAsync">حذف</button>
            </div>
        </div>
    </div>
}

@code {
    private bool busy;
    private bool formOpen;
    private bool messageIsError;
    private int? editingTransactionId;
    private int? pendingDeleteTransactionId;
    private string? message;
    private List<Asset> assets = new();
    private List<InvestmentTransaction> transactions = new();
    private List<AssetSummary> holdings = new();
    private List<StockSearchResult> stockSuggestions = new();
    private List<StockSearchResult> manualSuggestions = new();

    private string entryMode = "stock";
    private string manualType = "Fund"; // default: Fund (was Gold)
    private string stockQuery = string.Empty;
    private string assetCode = string.Empty;
    private string assetName = string.Empty;
    private string transactionType = "Buy";
    private string dividendKind = "Cash"; // "Cash" or "Stock"
    private DateTime transactionDate = DateTime.Today;
    private decimal? quantity;
    private decimal? pricePerUnit;
    private decimal? fees;
    private decimal? manufacturingFeePerGram;
    private decimal? dailyAccrualAnnualRatePercent;
    private decimal? dividendAmount;
    private decimal? freeSharesQuantity;
    private decimal? freeSharesMarketPrice;

    private bool IsGold => entryMode == "other" && manualType == "Gold";
    private bool IsSilver => entryMode == "other" && manualType == "Silver";
    private bool IsGoldOrSilver => IsGold || IsSilver;
    private bool IsTcd => entryMode == "other" && manualType == "TCD";
    private bool IsDividend => transactionType == "Dividend";
    private string TodayIso => DateTime.Today.ToString("yyyy-MM-dd");
    private bool IsFutureTransactionDate => !IsTcd && transactionDate.Date > DateTime.Today;
    private bool DividendInvalid => IsDividend && dividendKind == "Cash" && (!dividendAmount.HasValue || dividendAmount.Value <= 0);
    private bool FreeSharesInvalid => IsDividend && dividendKind == "Stock" && ((freeSharesQuantity ?? 0m) <= 0);
    private bool IsSaveDisabled => busy || IsFutureTransactionDate || DividendInvalid || FreeSharesInvalid
        || (IsDividend && !CanSelectDividend)
        || IsTcdAnnualRateRequired
        || (transactionType == "Sell" && (!CanSelectSell || SellExceedsAvailable || SellNetInvalid || SellExceedsMarketValue));
    private decimal? TcdExistingRate => IsTcd ? CurrentFormAsset?.DailyAccrualAnnualRatePercent : null;
    private bool IsTcdAnnualRateRequired => IsTcd
        && transactionType == "Buy"
        && CurrentFormAsset == null
        && (!dailyAccrualAnnualRatePercent.HasValue || dailyAccrualAnnualRatePercent.Value <= 0);
    private bool SellNetInvalid => transactionType == "Sell" && (quantity ?? 0m) > 0m && TransactionNetAmount < 0;
    private string NetSellWarningText => IsTcd
        ? "صافي السحب بعد الرسوم لا يمكن أن يكون أكبر من القيمة السوقية للأصل"
        : "صافي البيع بعد الرسوم لا يمكن أن يكون أكبر من القيمة السوقية للأصل";
    private string StockQueryInput
    {
        get => stockQuery;
        set
        {
            stockQuery = ToAssetCode(value).ToUpperInvariant();
            assetCode = stockQuery.Trim().ToUpperInvariant();
            assetName = string.Empty;
        }
    }
    private string AssetCodeInput
    {
        get => assetCode;
        set
        {
            assetCode = ToAssetCode(value).Trim().ToUpperInvariant();
            assetName = string.Empty;
        }
    }
    private decimal TransactionNetAmount
    {
        get
        {
            var amount = quantity ?? 0m;
            if (IsDividend)
            {
                return dividendKind == "Stock" ? 0m : dividendAmount ?? 0m;
            }

            var price = IsTcd ? 1m : pricePerUnit ?? 0m;
            var feeAmount = IsTcd ? 0m : fees ?? 0m;
            var metalAdjustment = IsGoldOrSilver ? amount * (manufacturingFeePerGram ?? 0m) : 0m;
            var gross = IsTcd ? amount : amount * price + metalAdjustment;

            return transactionType == "Buy" ? gross + feeAmount : gross - feeAmount;
        }
    }
    private string SubmitLabel => transactionType == "Buy"
        ? IsTcd ? "إيداع" : "شراء"
        : transactionType == "Dividend" ? "حفظ"
        : IsTcd ? "سحب" : "بيع";
    private Asset? CurrentFormAsset
    {
        get
        {
            if (editingTransactionId.HasValue)
            {
                var current = transactions.FirstOrDefault(t => t.TransactionId == editingTransactionId.Value);
                if (current != null)
                {
                    return assets.FirstOrDefault(a => a.AssetId == current.AssetId);
                }
            }

            var normalizedCode = assetCode.Trim().ToUpperInvariant();
            return string.IsNullOrWhiteSpace(normalizedCode)
                ? null
                : assets.FirstOrDefault(a => string.Equals(a.AssetCode, normalizedCode, StringComparison.OrdinalIgnoreCase));
        }
    }
    private AssetSummary? CurrentFormSummary
    {
        get
        {
            var asset = CurrentFormAsset;
            return asset == null ? null : holdings.FirstOrDefault(h => h.Asset.AssetId == asset.AssetId);
        }
    }
    private List<InvestmentTransaction> CurrentAssetTransactionsExcludingEdit
    {
        get
        {
            var asset = CurrentFormAsset;
            if (asset == null)
            {
                return new();
            }

            return transactions
                .Where(t => t.AssetId == asset.AssetId && t.TransactionId != editingTransactionId)
                .OrderBy(t => t.TransactionDate)
                .ThenBy(t => t.TransactionId)
                .ToList();
        }
    }
    private bool CanSelectSell => CurrentAssetTransactionsExcludingEdit.Any(t => t.TransactionType == TransactionKind.Buy);
    private bool CanSelectDividend => entryMode == "stock" && CurrentAssetTransactionsExcludingEdit.Any(t => t.TransactionType == TransactionKind.Buy);
    private decimal AvailableSellAmount
    {
        get
        {
            var asset = CurrentFormAsset;
            if (asset == null)
            {
                return 0m;
            }

            var existing = CurrentAssetTransactionsExcludingEdit;
            var accrualStartDate = PortfolioService.GetDailyAccrualStartDate(asset, existing, transactionDate);
            var unitsHeld = PortfolioService.CalculateUnitsHeld(asset, existing, accrualStartDate);
            if (!asset.IsDailyAccrualFund)
            {
                return Math.Max(0m, unitsHeld);
            }

            var unitPrice = PortfolioService.GetDailyAccrualUnitPrice(asset, transactionDate, accrualStartDate);
            return Math.Max(0m, unitsHeld * unitPrice);
        }
    }
    private bool SellExceedsAvailable => transactionType == "Sell"
        && quantity.HasValue
        && quantity.Value > 0
        && quantity.Value > AvailableSellAmount + 0.0000001m;
    private decimal AvailableSellMarketValue
    {
        get
        {
            var asset = CurrentFormAsset;
            var summary = CurrentFormSummary;
            if (asset == null || summary == null)
            {
                return 0m;
            }

            var editedSell = editingTransactionId.HasValue
                ? transactions.FirstOrDefault(t => t.TransactionId == editingTransactionId.Value && t.TransactionType == TransactionKind.Sell)
                : null;

            var editedNet = editedSell?.AssetId == asset.AssetId ? editedSell.NetAmount : 0m;
            return Math.Max(0m, summary.CurrentValue + editedNet);
        }
    }
    private bool SellExceedsMarketValue => transactionType == "Sell"
        && quantity.HasValue
        && quantity.Value > 0
        && TransactionNetAmount > AvailableSellMarketValue + 0.01m;
    private string AvailableSellLabel => $"{AvailableSellAmount:N2}";
    private string? AvailableSellMaxAttribute => transactionType == "Sell"
        ? AvailableSellAmount.ToString("0.#####", System.Globalization.CultureInfo.InvariantCulture)
        : null;

    protected override async Task OnInitializedAsync()
    {
        if (!await Eodhd.HasApiKeyAsync())
        {
            Nav.NavigateTo("/", replace: true);
            return;
        }

        Balance.Changed += OnBalanceChanged;
        await ReloadAsync();
    }

    private void OnBalanceChanged() => InvokeAsync(StateHasChanged);

    private async Task ReloadAsync()
    {
        assets = await Database.GetAssetsAsync();
        transactions = await Database.GetTransactionsAsync();
        holdings = await Portfolio.GetHoldingsAsync();
    }

    private void OpenForm(string mode)
    {
        if (formOpen && entryMode == mode)
        {
            CloseForm();
            return;
        }

        ResetForm(keepMode: true);
        entryMode = mode;
        formOpen = true;
        if (mode == "other")
        {
            OnManualTypeChanged();
        }
    }

    private void CloseForm()
    {
        ResetForm();
        formOpen = false;
    }

    private async Task OnStockQueryChangedAsync()
    {
        stockSuggestions.Clear();
        manualSuggestions.Clear();

        if (string.IsNullOrWhiteSpace(stockQuery))
        {
            return;
        }

        var local = await Database.SearchAssetsByPrefixAsync(stockQuery);
        stockSuggestions = local.Select(a => new StockSearchResult(a.AssetCode, a.AssetName, a.Currency, a.ExternalTicker ?? a.AssetCode)).ToList();

        if (stockSuggestions.Count == 0)
        {
            stockSuggestions = await Eodhd.SearchEgyptStocksAsync(stockQuery);
        }
        EnsureTransactionTypeAllowed();
    }

    private void PickStock(StockSearchResult item)
    {
        stockQuery = item.Code;
        assetCode = item.Code;
        assetName = item.Name;
        stockSuggestions.Clear();
        EnsureTransactionTypeAllowed();
    }

    private async Task OnManualAssetCodeChangedAsync()
    {
        manualSuggestions.Clear();

        if (string.IsNullOrWhiteSpace(assetCode))
        {
            return;
        }

        var matches = await Database.SearchAssetsByPrefixAsync(assetCode, ManualSearchAssetType, IsTcd ? true : false);
        manualSuggestions = matches
            .Select(a => new StockSearchResult(a.AssetCode, a.AssetName, a.Currency, a.ExternalTicker ?? a.AssetCode))
            .ToList();
        EnsureTransactionTypeAllowed();
    }

    private void PickManualAsset(StockSearchResult item)
    {
        assetCode = item.Code;
        assetName = item.Name;
        manualSuggestions.Clear();
        EnsureTransactionTypeAllowed();
    }

    private void OnAssetNameChanged(ChangeEventArgs e)
    {
        assetName = ToAscii(e.Value?.ToString() ?? string.Empty);
    }

    private void OnManualTypeChanged()
    {
        manualSuggestions.Clear();
        if (manualType == "TCD")
        {
            assetCode = "TCD";
            assetName = "Thndr Cloud Daily";
            pricePerUnit = 1m;
            fees = null;
            dailyAccrualAnnualRatePercent = null;
            transactionDate = DateTime.Today;
            EnsureTransactionTypeAllowed();
            return;
        }

        assetCode = string.Empty;
        assetName = string.Empty;
        pricePerUnit = null;
        dailyAccrualAnnualRatePercent = null;
        EnsureTransactionTypeAllowed();
    }

    private async Task SaveTransactionAsync()
    {
        try
        {
            busy = true;
            message = null;
            if (IsFutureTransactionDate)
            {
                throw new InvalidOperationException("لا يمكن تسجيل عملية بتاريخ مستقبلي.");
            }
            if (IsTcd)
            {
                transactionDate = DateTime.Today;
            }
            if (IsTcdAnnualRateRequired)
            {
                throw new InvalidOperationException("النسبة السنوية مطلوبة عند إضافة صندوق ثاندر كلاود لأول مرة.");
            }
            if (IsTcd && dailyAccrualAnnualRatePercent.HasValue && dailyAccrualAnnualRatePercent.Value <= 0)
            {
                throw new InvalidOperationException("النسبة السنوية يجب أن تكون أكبر من صفر.");
            }
            if (IsDividend)
            {
                if (!CanSelectDividend)
                {
                    throw new InvalidOperationException("الأرباح متاحة بعد وجود عملية شراء سابقة للسهم.");
                }

                if (dividendKind == "Cash" && DividendInvalid)
                {
                    throw new InvalidOperationException("الربح يجب أن يكون أكبر من صفر.");
                }

                if (dividendKind == "Stock" && FreeSharesInvalid)
                {
                    throw new InvalidOperationException("العدد يجب أن يكون أكبر من صفر.");
                }

            }
            if (transactionType == "Sell" && !CanSelectSell)
            {
                throw new InvalidOperationException(IsTcd
                    ? "لا يمكن تسجيل سحب قبل وجود إيداع سابق لهذا الأصل."
                    : "لا يمكن تسجيل بيع قبل وجود عملية شراء سابقة لهذا الأصل.");
            }
            if (SellExceedsAvailable)
            {
                throw new InvalidOperationException("القيمة تتخطى المتاح لهذا الأصل.");
            }
            if (SellNetInvalid)
            {
                throw new InvalidOperationException(NetSellWarningText);
            }
            if (SellExceedsMarketValue)
            {
                throw new InvalidOperationException(NetSellWarningText);
            }
            await EnsureSellHasPriorBuyAsync();
            Asset? existingStockBeforeSave = null;
            var hadPreviousStockTransactions = false;
            if (!editingTransactionId.HasValue && entryMode == "stock" && !string.IsNullOrWhiteSpace(assetCode))
            {
                existingStockBeforeSave = await Database.GetAssetByCodeAsync(assetCode);
                if (existingStockBeforeSave?.AssetType == AssetType.Stock)
                {
                    hadPreviousStockTransactions = (await Database.GetTransactionsByAssetAsync(existingStockBeforeSave.AssetId)).Count > 0;
                }
            }

            var asset = await EnsureAssetAsync();
            await UpdateTcdAnnualRateIfNeededAsync(asset);

            var kind = Enum.Parse<TransactionKind>(transactionType);
            var resolvedDividendKind = DividendKind.Cash;

            decimal transactionAmount;
            decimal resolvedPrice;

            if (IsDividend)
            {
                if (dividendKind == "Stock")
                {
                    resolvedDividendKind = DividendKind.Stock;
                    
                    var summary = holdings.FirstOrDefault(h => h.Asset.AssetId == asset.AssetId);
                    decimal baseUnits = summary?.TotalUnitsHeld ?? 0m;
                    if (editingTransactionId.HasValue)
                    {
                        var oldTx = transactions.FirstOrDefault(t => t.TransactionId == editingTransactionId.Value);
                        if (oldTx != null && oldTx.TransactionType == TransactionKind.Dividend && oldTx.DividendKind == DividendKind.Stock)
                        {
                            baseUnits -= oldTx.Quantity;
                        }
                    }

                    decimal ratio = freeSharesQuantity ?? 0m;
                    transactionAmount = ratio * baseUnits;
                    resolvedPrice = 0m;
                }
                else
                {
                    resolvedDividendKind = DividendKind.Cash;
                    transactionAmount = dividendAmount ?? 0m;
                    resolvedPrice = 0m;
                }
            }
            else
            {
                transactionAmount = quantity ?? 0m;
                resolvedPrice = IsDividend ? 0m : pricePerUnit ?? 0m;
            }

            var transaction = await Portfolio.BuildTransactionAsync(
                asset,
                kind,
                transactionDate,
                transactionAmount,
                resolvedPrice,
                IsTcd || IsDividend ? 0m : fees ?? 0m,
                IsDividend ? 0m : manufacturingFeePerGram ?? 0m,
                null,
                editingTransactionId ?? 0,
                resolvedDividendKind);
            await Database.SaveTransactionAsync(transaction);

            if (!editingTransactionId.HasValue && entryMode == "other" && !asset.IsDailyAccrualFund && (pricePerUnit ?? 0m) > 0)
            {
                await Database.SavePriceAsync(new AssetPrice
                {
                    AssetId = asset.AssetId,
                    PriceDate = transactionDate.Date,
                    PriceValue = pricePerUnit!.Value,
                    Source = PriceSource.Manual
                });
            }

            if (existingStockBeforeSave != null && hadPreviousStockTransactions)
            {
                await UpdateExistingStockPriceFromTransactionIfNewerAsync(asset, transactionDate, pricePerUnit ?? 0m);
            }

            var wasEditing = editingTransactionId.HasValue;
            CloseForm();
            await ReloadAsync();

            // Scroll to top of transactions list so user can see the newly added transaction
            await JS.InvokeVoidAsync("investyScrollTo", "transactions-list-start");

            await ShowMessageAsync(wasEditing ? "تم تعديل العملية." : "تم إجراء العملية.");
        }
        catch (Exception ex)
        {
            await ShowMessageAsync(ex.Message, isError: true);
        }
        finally
        {
            busy = false;
        }
    }

    private async Task<Asset> EnsureAssetAsync()
    {
        if (editingTransactionId.HasValue)
        {
            var current = await Database.GetTransactionAsync(editingTransactionId.Value);
            var currentAsset = current == null ? null : await Database.GetAssetAsync(current.AssetId);
            if (currentAsset != null)
            {
                return currentAsset;
            }
        }

        if (string.IsNullOrWhiteSpace(assetCode))
        {
            throw new InvalidOperationException("كود الأصل مطلوب.");
        }

        var existing = await Database.GetAssetByCodeAsync(assetCode);
        if (existing != null)
        {
            return existing;
        }

        if (string.IsNullOrWhiteSpace(assetName))
        {
            assetName = assetCode.Trim().ToUpperInvariant();
        }

        var asset = new Asset
        {
            AssetCode = assetCode,
            AssetName = ToAscii(assetName),
            AssetType = entryMode == "stock" ? AssetType.Stock
                : manualType == "Gold" ? AssetType.Gold
                : manualType == "Silver" ? AssetType.Silver
                : manualType == "Fund" ? AssetType.Fund
                : AssetType.Other,
            ExternalTicker = entryMode == "stock" ? assetCode + ".EGX" : null,
            IsDailyAccrualFund = manualType == "TCD",
            DailyAccrualAnnualRatePercent = manualType == "TCD" ? dailyAccrualAnnualRatePercent!.Value : 0m,
            GoldCashbackPerGram = (manualType == "Gold" || manualType == "Silver") ? 0m : 0m
        };

        await Database.SaveAssetAsync(asset);
        var created = (await Database.GetAssetByCodeAsync(asset.AssetCode))!;
        if (created.AssetType == AssetType.Stock && !string.IsNullOrWhiteSpace(created.ExternalTicker))
        {
            await TrySeedNewStockPriceAsync(created);
        }

        return created;
    }

    private async Task UpdateTcdAnnualRateIfNeededAsync(Asset asset)
    {
        if (!asset.IsDailyAccrualFund || transactionType != "Buy" || !dailyAccrualAnnualRatePercent.HasValue)
        {
            return;
        }

        if (asset.DailyAccrualAnnualRatePercent == dailyAccrualAnnualRatePercent.Value)
        {
            return;
        }

        asset.DailyAccrualAnnualRatePercent = dailyAccrualAnnualRatePercent.Value;
        await Database.SaveAssetAsync(asset);
    }

    private async Task EnsureSellHasPriorBuyAsync()
    {
        if (transactionType != "Sell")
        {
            return;
        }

        Asset? asset = null;
        if (editingTransactionId.HasValue)
        {
            var current = await Database.GetTransactionAsync(editingTransactionId.Value);
            asset = current == null ? null : await Database.GetAssetAsync(current.AssetId);
        }
        else if (!string.IsNullOrWhiteSpace(assetCode))
        {
            asset = await Database.GetAssetByCodeAsync(assetCode);
        }

        if (asset == null)
        {
            throw new InvalidOperationException(IsTcd
                ? "لا يمكن تسجيل سحب قبل وجود إيداع سابق لهذا الأصل."
                : "لا يمكن تسجيل بيع قبل وجود عملية شراء سابقة لهذا الأصل.");
        }

        var existing = await Database.GetTransactionsByAssetAsync(asset.AssetId);
        if (editingTransactionId.HasValue)
        {
            existing = existing.Where(t => t.TransactionId != editingTransactionId.Value).ToList();
        }

        if (!existing.Any(t => t.TransactionType == TransactionKind.Buy))
        {
            throw new InvalidOperationException(asset.IsDailyAccrualFund
                ? "لا يمكن تسجيل سحب قبل وجود إيداع سابق لهذا الأصل."
                : "لا يمكن تسجيل بيع قبل وجود عملية شراء سابقة لهذا الأصل.");
        }
    }

    private async Task TrySeedNewStockPriceAsync(Asset asset)
    {
        var latest = await Eodhd.FetchLatestPriceAsync(asset.ExternalTicker ?? asset.AssetCode);
        if (latest == null)
        {
            return;
        }

        await Database.SavePriceAsync(new AssetPrice
        {
            AssetId = asset.AssetId,
            PriceDate = latest.Value.Date.Date,
            PriceValue = latest.Value.Price,
            Source = PriceSource.Eodhd
        });
    }

    private async Task UpdateExistingStockPriceFromTransactionIfNewerAsync(Asset asset, DateTime date, decimal price)
    {
        if (asset.AssetType != AssetType.Stock || price <= 0)
        {
            return;
        }

        var latest = await Database.GetLatestPriceAsync(asset.AssetId);
        if (latest != null && latest.PriceDate.Date > date.Date)
        {
            return;
        }

        await Database.SavePriceAsync(new AssetPrice
        {
            AssetId = asset.AssetId,
            PriceDate = date.Date,
            PriceValue = price,
            Source = PriceSource.Manual
        });
    }

    private async Task EditTransactionAsync(int id)
    {
        var transaction = await Database.GetTransactionAsync(id);
        if (transaction == null)
        {
            return;
        }

        var asset = await Database.GetAssetAsync(transaction.AssetId);
        if (asset == null)
        {
            return;
        }

        editingTransactionId = id;
        formOpen = true;
        entryMode = asset.AssetType == AssetType.Stock ? "stock" : "other";
        manualType = asset.IsDailyAccrualFund ? "TCD"
            : asset.AssetType == AssetType.Gold ? "Gold"
            : asset.AssetType == AssetType.Silver ? "Silver"
            : asset.AssetType == AssetType.Fund ? "Fund"
            : "Other";
        stockQuery = asset.AssetCode;
        assetCode = asset.AssetCode;
        assetName = asset.AssetName;
        transactionType = transaction.TransactionType.ToString();
        dividendKind = transaction.DividendKind == DividendKind.Stock ? "Stock" : "Cash";
        transactionDate = transaction.TransactionDate;
        quantity = asset.IsDailyAccrualFund ? transaction.TotalAmount : transaction.Quantity;
        dividendAmount = transaction.TransactionType == TransactionKind.Dividend && transaction.DividendKind == DividendKind.Cash ? transaction.NetAmount : null;
        freeSharesQuantity = transaction.TransactionType == TransactionKind.Dividend && transaction.DividendKind == DividendKind.Stock 
            ? transaction.Quantity / Math.Max(1m, (holdings.FirstOrDefault(h => h.Asset.AssetId == transaction.AssetId)?.TotalUnitsHeld ?? 1m) - transaction.Quantity) 
            : null;
        freeSharesMarketPrice = null;
        pricePerUnit = transaction.PricePerUnit;
        fees = transaction.Fees == 0 ? null : transaction.Fees;
        manufacturingFeePerGram = transaction.ManufacturingFeePerGram == 0 ? null : transaction.ManufacturingFeePerGram;
        dailyAccrualAnnualRatePercent = null;
        EnsureTransactionTypeAllowed();
        await InvokeAsync(StateHasChanged);
        await JS.InvokeVoidAsync("investyScrollTo", "transaction-editor");
    }

    private void RequestDeleteTransaction(int id)
    {
        pendingDeleteTransactionId = id;
    }

    private void CancelDeleteTransaction()
    {
        pendingDeleteTransactionId = null;
    }

    private async Task ConfirmDeleteTransactionAsync()
    {
        if (!pendingDeleteTransactionId.HasValue)
        {
            return;
        }

        var id = pendingDeleteTransactionId.Value;
        pendingDeleteTransactionId = null;
        try
        {
            var transaction = await Database.GetTransactionAsync(id);
            var asset = transaction == null ? null : await Database.GetAssetAsync(transaction.AssetId);
            if (transaction != null && asset != null)
            {
                var remaining = (await Database.GetTransactionsByAssetAsync(asset.AssetId))
                    .Where(t => t.TransactionId != id)
                    .ToList();
                if (remaining.Count > 0)
                {
                    var accrualStartDate = PortfolioService.GetDailyAccrualStartDate(asset, remaining);
                    try
                    {
                        PortfolioService.ValidateTransactionSequence(asset, remaining, accrualStartDate);
                    }
                    catch (InvalidOperationException ex)
                    {
                        throw new InvalidOperationException(ex.Message);
                    }
                }
            }

            await Database.DeleteTransactionAsync(id);
            await ReloadAsync();
            await ShowMessageAsync("تم حذف العملية.");
        }
        catch (Exception ex)
        {
            await ShowMessageAsync(ex.Message, isError: true);
        }
    }

    private async Task ShowMessageAsync(string text, bool isError = false)
    {
        message = text;
        messageIsError = isError;
        StateHasChanged();
        await Task.Delay(1750);
        if (message == text)
        {
            message = null;
            messageIsError = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ResetForm(bool keepMode = false)
    {
        editingTransactionId = null;
        stockQuery = string.Empty;
        assetCode = string.Empty;
        assetName = string.Empty;
        transactionType = "Buy";
        dividendKind = "Cash";
        transactionDate = DateTime.Today;
        quantity = null;
        pricePerUnit = null;
        fees = null;
        manufacturingFeePerGram = null;
        dailyAccrualAnnualRatePercent = null;
        dividendAmount = null;
        freeSharesQuantity = null;
        freeSharesMarketPrice = null;
        stockSuggestions.Clear();
        if (!keepMode)
        {
            entryMode = "stock";
            manualType = "Fund";
        }
    }

    private void EnsureTransactionTypeAllowed()
    {
        if (transactionType == "Sell" && !CanSelectSell)
        {
            transactionType = "Buy";
        }

        if (transactionType == "Dividend" && !CanSelectDividend)
        {
            transactionType = "Buy";
        }
    }

    private string BalanceClass => Balance.HideBalances ? "balance-value is-hidden" : "balance-value";
    private string MoneyValue(decimal value) => $"{value.ToString("N2")} \u062c.\u0645";
    private AssetType ManualSearchAssetType => manualType switch
    {
        "Gold" => AssetType.Gold,
        "Silver" => AssetType.Silver,
        "Fund" or "TCD" => AssetType.Fund,
        _ => AssetType.Other
    };
    private static string CodeClass(Asset? asset) => asset?.IsDailyAccrualFund == true ? "cloud"
        : asset?.AssetType == AssetType.Gold ? "gold"
        : asset?.AssetType == AssetType.Silver ? "silver"
        : asset?.AssetType == AssetType.Fund ? "fund"
        : asset?.AssetType != AssetType.Stock ? "blue"
        : string.Empty;
    private static string AssetTypeLabel(Asset? asset) => asset?.IsDailyAccrualFund == true ? "صندوق تراكمي"
        : asset?.AssetType == AssetType.Stock ? "سهم"
        : asset?.AssetType == AssetType.Gold ? "ذهب"
        : asset?.AssetType == AssetType.Silver ? "فضة"
        : asset?.AssetType == AssetType.Fund ? "صندوق"
        : asset?.AssetType == AssetType.Crypto ? "كريبتو"
        : asset?.AssetType == AssetType.ETF ? "وثيقة"
        : "أخرى";

    private static string TransactionTypeLabel(InvestmentTransaction transaction, Asset? asset)
    {
        var isTcd = asset?.IsDailyAccrualFund == true;
        return transaction.TransactionType == TransactionKind.Dividend
            ? (transaction.DividendKind == DividendKind.Stock ? "أسهم مجانية" : "أرباح نقدية")
            : transaction.TransactionType == TransactionKind.Buy
            ? isTcd ? "إيداع" : "شراء"
            : isTcd ? "سحب" : "بيع";
    }

    private static string TransactionTypeClass(InvestmentTransaction transaction) =>
        transaction.TransactionType == TransactionKind.Dividend
            ? "transaction-type-dividend"
            : transaction.TransactionType == TransactionKind.Buy ? "transaction-type-buy" : "transaction-type-sell";

    private static string ToAscii(string value) => new(value.Where(c => c <= 127).ToArray());
    private static string ToAssetCode(string value) => new(value
        .Where(c => c is >= 'A' and <= 'Z' or >= 'a' and <= 'z')
        .ToArray());

    public void Dispose()
    {
        Balance.Changed -= OnBalanceChanged;
    }
}
