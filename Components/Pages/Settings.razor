@page "/settings"
@inject EodhdMobileService Eodhd
@inject LocalDatabase Database
@inject PortfolioService Portfolio
@inject ExportService Exporter
@inject NavigationManager Nav

<PageTitle>الإعدادات</PageTitle>

<section class="page-head">
    <div>
        <h1>الإعدادات</h1>
        <p>مفتاح EODHD وبيانات الحصة</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="notice">@message</div>
}

<section class="surface">
    <div class="section-title">
        <h2>الأسعار والبيانات</h2>
    </div>
    <div class="head-actions inline-actions" style="margin-top:12px;">
        <button class="ghost export-button" @onclick="ExportAsync" disabled="@busy">تصدير ملف</button>
        <button class="primary" @onclick="SyncPricesAsync" disabled="@busy">مزامنة الأسعار</button>
    </div>
</section>

<section class="surface">
    <div class="section-title">
        <h2>حالة المفتاح</h2>
        <button class="ghost" @onclick="LoadStatusAsync">تحديث</button>
    </div>

    @if (loadingStatus)
    {
        <p>جاري تحميل بيانات المفتاح...</p>
    }
    else if (status == null)
    {
        <p>لم يتم تحميل بيانات المفتاح.</p>
    }
    else
    {
        <div class="settings-list">
            <span>الاسم <b>@status.Name</b></span>
            <span>البريد <b>@status.Email</b></span>
            <span>الخطة <b>@status.SubscriptionType</b></span>
            <span>المتبقي <b>@status.Remaining</b></span>
            <span>المستخدم اليوم <b>@status.ApiRequestsUsedToday</b></span>
            <span>الإجمالي <b>@status.TotalAvailable</b></span>
        </div>
    }
</section>

<section class="surface">
    <div class="section-title">
        <h2>تغيير المفتاح</h2>
    </div>
    <div class="mobile-form">
        <label>
            مفتاح EODHD جديد
            <input class="field" @bind="newApiKey" />
        </label>
    </div>
    <div class="form-actions">
        <button class="danger" @onclick="ClearAsync">مسح المفتاح</button>
        <button class="primary" @onclick="SaveAsync" disabled="@busy">حفظ</button>
    </div>
</section>

@code {
    private EodhdUserStatus? status;
    private string newApiKey = string.Empty;
    private string? message;
    private bool busy;
    private bool loadingStatus;
    private List<Asset> assets = new();

    protected override async Task OnInitializedAsync()
    {
        if (!await Eodhd.HasApiKeyAsync())
        {
            Nav.NavigateTo("/", replace: true);
            return;
        }

        assets = await Database.GetAssetsAsync();
        await LoadStatusAsync();
    }

    private async Task LoadStatusAsync()
    {
        loadingStatus = true;
        status = await Eodhd.GetUserStatusAsync();
        loadingStatus = false;
    }

    private async Task SyncPricesAsync()
    {
        busy = true;
        var synced = 0;
        foreach (var asset in assets.Where(a => a.AssetType == AssetType.Stock && !string.IsNullOrWhiteSpace(a.ExternalTicker)))
        {
            var price = await Eodhd.FetchLatestPriceAsync(asset.ExternalTicker!);
            if (price == null)
            {
                continue;
            }

            await Database.SavePriceAsync(new AssetPrice
            {
                AssetId = asset.AssetId,
                PriceDate = price.Value.Date.Date,
                PriceValue = price.Value.Price,
                Source = PriceSource.Eodhd
            });
            synced++;
        }

        busy = false;
        await ShowMessageAsync(synced == 0 ? "لم يتم تحديث أي سعر." : $"تم تحديث {synced} سعر.");
    }

    private async Task ExportAsync()
    {
        try
        {
            busy = true;
            var path = await Exporter.ExportWorkbookAsync();
            await ShowMessageAsync($"تم حفظ الملف في التنزيلات: {Path.GetFileName(path)}");
        }
        catch (Exception ex)
        {
            await ShowMessageAsync($"تعذر حفظ الملف: {ex.Message}");
        }
        finally
        {
            busy = false;
        }
    }

    private async Task SaveAsync()
    {
        busy = true;
        var result = await Eodhd.SaveAndValidateApiKeyAsync(newApiKey);
        busy = false;
        if (result == null)
        {
            await ShowMessageAsync("المفتاح غير صحيح أو لا يوجد اتصال.");
            return;
        }

        status = result;
        newApiKey = string.Empty;
        await ShowMessageAsync("تم تحديث المفتاح.");
    }

    private async Task ClearAsync()
    {
        await Eodhd.ClearApiKeyAsync();
        Nav.NavigateTo("/", replace: true);
    }

    private async Task ShowMessageAsync(string text)
    {
        message = text;
        StateHasChanged();
        await Task.Delay(1750);
        if (message == text)
        {
            message = null;
            await InvokeAsync(StateHasChanged);
        }
    }
}
